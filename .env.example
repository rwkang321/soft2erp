SOFT2ERP_DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SOFT2ERP_DB_USERNAME=postgres
SOFT2ERP_DB_PASSWORD=<database-password>
SOFT2ERP_DB_POOL_MAX=10
SOFT2ERP_DB_POOL_MIN=2

# Supabase project/API settings
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_PROJECT_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# GitHub repository/API settings
GITHUB_OWNER=<github-id-or-org>
GITHUB_REPOSITORY=soft2erp
GITHUB_TOKEN=<personal-access-token>
GITHUB_DEFAULT_BRANCH=main
